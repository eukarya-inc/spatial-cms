# ════════════════════════════════════════════════════════════
# Spatial CMS 部署环境变量
# 复制为 .env 并填入真实值
# ════════════════════════════════════════════════════════════

# === 域名（必填） ===
# 必须是你拥有且已配置 DNS 的域名
# A 记录指向 Lightsail 静态 IP
DOMAIN=cms.yourdomain.com

# === RDS 数据库（必填） ===
# 从 AWS RDS console 获取 endpoint
RDS_HOST=your-instance.xxx.ap-northeast-1.rds.amazonaws.com
RDS_USER=spatial_cms_admin
# 从 AWS Secrets Manager 读取，或 RDS 创建时记下的密码
RDS_PASSWORD=

# === Keycloak 管理员密码（必填） ===
# 用于登录 Keycloak admin console（/auth/ 路径）
# 生成方法: openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=
