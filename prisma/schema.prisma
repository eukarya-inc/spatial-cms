generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─── Enums ───────────────────────────────────────────

enum EntityStatus {
  draft
  active
  archived
}

enum ProposalStatus {
  pending
  approved
  rejected
}

enum ProposalSource {
  human
  machine
  import_
}

enum SnapshotStatus {
  draft
  ready
  published
}

enum PublicationType {
  publish
  rollback
}

enum PublicationStatus {
  pending
  completed
  failed
}

// ─── Definition Kernel Enums ─────────────────────────

enum GeometryType {
  NONE
  POINT
  LINESTRING
  POLYGON
  MIXED
}

enum FieldType {
  string
  number
  boolean
  date
  json
  enum_
  reference
  geometry
}

enum GovernanceTargetType {
  model
  dataset
}

enum ApprovalMode {
  manual
  auto
}

enum PublishMode {
  manual
  auto
}

// ─── Models ──────────────────────────────────────────

model Entity {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type              String
  modelDefinitionId String?           @map("model_definition_id") @db.Uuid
  properties        Json              @default("{}")
  status            EntityStatus      @default(draft)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  modelDefinition ModelDefinition? @relation(fields: [modelDefinitionId], references: [id])
  versions        EntityVersion[]
  proposals       Proposal[]
  geometries      EntityGeometry[]

  @@index([type])
  @@index([status])
  @@index([modelDefinitionId])
  @@map("entity")
}

model EntityGeometry {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId String @map("entity_id") @db.Uuid
  fieldKey String @map("field_key")
  geometry Unsupported("geometry")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, fieldKey])
  @@index([entityId])
  @@map("entity_geometry")
}

model EntityVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId      String   @map("entity_id") @db.Uuid
  versionNumber Int      @map("version_number")
  snapshot      Json
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@map("entity_version")
}

model Proposal {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId       String?        @map("entity_id") @db.Uuid
  proposedChange Json           @map("proposed_change")
  source         ProposalSource @default(human)
  status         ProposalStatus @default(pending)
  createdAt      DateTime       @default(now()) @map("created_at")

  entity Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([status])
  @@map("proposal")
}

model DatasetDefinition {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId         String   @map("workspace_id") @db.Uuid
  name                String
  entityTypes         Json     @map("entity_types")
  filterRule          Json?    @map("filter_rule")
  projectionRule      Json?    @map("projection_rule")
  primaryGeometryRule Json?    @map("primary_geometry_rule")
  publishToDelivery   Boolean  @default(true)  @map("publish_to_delivery")
  publishToOgc        Boolean  @default(false) @map("publish_to_ogc")
  description         String?
  license             String?
  source              String?
  contactName         String?  @map("contact_name")
  contactEmail        String?  @map("contact_email")
  keywords            Json?    @default("[]")
  createdAt           DateTime @default(now()) @map("created_at")

  workspace          Workspace             @relation(fields: [workspaceId], references: [id])
  snapshots          DatasetSnapshot[]
  activeReleaseState ActiveReleaseState?
  modelBindings      DatasetModelBinding[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("dataset_definition")
}

model DatasetSnapshot {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetDefinitionId String         @map("dataset_definition_id") @db.Uuid
  version             Int
  manifest            Json
  status              SnapshotStatus @default(draft)
  createdAt           DateTime       @default(now()) @map("created_at")

  datasetDefinition DatasetDefinition  @relation(fields: [datasetDefinitionId], references: [id], onDelete: Cascade)
  publications      Publication[]
  activeFor         ActiveReleaseState?

  @@unique([datasetDefinitionId, version])
  @@index([datasetDefinitionId])
  @@map("dataset_snapshot")
}

model Publication {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetSnapshotId String            @map("dataset_snapshot_id") @db.Uuid
  type              PublicationType
  status            PublicationStatus @default(pending)
  createdAt         DateTime          @default(now()) @map("created_at")

  datasetSnapshot DatasetSnapshot @relation(fields: [datasetSnapshotId], references: [id], onDelete: Cascade)

  @@index([datasetSnapshotId])
  @@map("publication")
}

model ActiveReleaseState {
  datasetDefinitionId String   @id @map("dataset_definition_id") @db.Uuid
  activeSnapshotId    String   @unique @map("active_snapshot_id") @db.Uuid
  updatedAt           DateTime @updatedAt @map("updated_at")

  datasetDefinition DatasetDefinition @relation(fields: [datasetDefinitionId], references: [id], onDelete: Cascade)
  activeSnapshot    DatasetSnapshot   @relation(fields: [activeSnapshotId], references: [id], onDelete: Restrict)

  @@map("active_release_state")
}

// ─── Definition Kernel Models ────────────────────────

model ModelDefinition {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId          String   @map("workspace_id") @db.Uuid
  key                  String
  name                 String
  description          String?
  primaryGeometryField String?  @map("primary_geometry_field")
  displayField         String?  @map("display_field")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  workspace       Workspace             @relation(fields: [workspaceId], references: [id])
  fields          FieldDefinition[]
  datasetBindings DatasetModelBinding[]
  entities        Entity[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("model_definition")
}

model FieldDefinition {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelDefinitionId String       @map("model_definition_id") @db.Uuid
  key               String
  label             String
  fieldType         FieldType    @map("field_type")
  isRequired        Boolean      @default(false) @map("is_required")
  defaultValue      Json?        @map("default_value")
  enumValues        Json?        @map("enum_values")
  validationJson    Json?        @map("validation_json")
  referenceModelKey String?      @map("reference_model_key")
  geometryType      GeometryType? @map("geometry_type")
  geometrySrid      Int?         @map("geometry_srid")
  geometryIs3D      Boolean?     @map("geometry_is_3d")
  orderIndex        Int          @default(0) @map("order_index")

  modelDefinition ModelDefinition @relation(fields: [modelDefinitionId], references: [id], onDelete: Cascade)

  @@unique([modelDefinitionId, key])
  @@index([modelDefinitionId])
  @@map("field_definition")
}

model DatasetModelBinding {
  id                  String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetDefinitionId String @map("dataset_definition_id") @db.Uuid
  modelDefinitionId   String @map("model_definition_id") @db.Uuid
  filterJson          Json?  @map("filter_json")
  projectionJson      Json?  @map("projection_json")

  datasetDefinition DatasetDefinition @relation(fields: [datasetDefinitionId], references: [id], onDelete: Cascade)
  modelDefinition   ModelDefinition   @relation(fields: [modelDefinitionId], references: [id], onDelete: Cascade)

  @@unique([datasetDefinitionId, modelDefinitionId])
  @@index([datasetDefinitionId])
  @@map("dataset_model_binding")
}

model GovernancePolicy {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetType      GovernanceTargetType  @map("target_type")
  targetId        String               @map("target_id") @db.Uuid
  requireProposal Boolean              @default(true) @map("require_proposal")
  approvalMode    ApprovalMode         @default(manual) @map("approval_mode")
  publishMode     PublishMode          @default(manual) @map("publish_mode")
  createdAt       DateTime             @default(now()) @map("created_at")

  @@unique([targetType, targetId])
  @@map("governance_policy")
}

model ApiKey {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  keyHash   String    @unique @map("key_hash")
  keyPrefix String    @map("key_prefix")
  scope     String    @default("delivery")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("api_key")
}

// Intra-deployment grouping. Lets one CMS deployment host multiple
// unrelated demo / project datasets without cross-contamination.
// All users see all workspaces (MVP — no per-user membership).
model Workspace {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  models   ModelDefinition[]
  datasets DatasetDefinition[]

  @@map("workspace")
}
